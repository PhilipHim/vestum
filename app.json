{
  "expo": {
    "name": "Lethe",
    "slug": "lethe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "lethe",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/jph-shark-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#111111"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Lethe needs camera access to scan clothing and take selfies for color analysis.",
        "NSPhotoLibraryUsageDescription": "Lethe needs photo library access to upload clothing and selfies.",
        "NSLocationWhenInUseUsageDescription": "Lethe uses your location to provide weather-based outfit suggestions."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111111"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/jph-shark-splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#111111"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Lethe needs camera access to scan clothing and take selfies for color analysis."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Lethe needs photo library access to upload clothing and selfies."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Lethe uses your location to provide weather-based outfit suggestions."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#D7A5B9"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
